{
  "name": "@pagefly/app-tailorkit",
  "version": "0.1.0",
  "private": true,
  "description": "PageFly internal TailorKit app-platform marketplace shell",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./manifest.ts",
    "./admin": "./src/admin/index.tsx",
    "./backend/plugin": "./src/backend/plugin.ts",
    "./product-editor-route-contract": "./src/admin/product-editor-island/route-contract.ts",
    "./domain/order-record": "./domain/order-record.ts",
    "./domain/order-property-matchers": "./domain/order-property-matchers.ts"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:admin",
    "build:with-theme": "npm run build && npm run build:theme",
    "build:server": "npm --workspace pagefly-server run build:apps -- --app tailorkit",
    "build:theme": "npm --workspace pagefly-app-platform-src run build -- --app tailorkit",
    "build:theme:standalone": "node ../../extensions/app-platform-src/scripts/build.mjs --app tailorkit",
    "build:admin": "npm run build:copied-routes-runtime && node scripts/materialize-admin-assets.mjs",
    "build:artifact": "npm run build:admin-runtime && npm run build:copied-routes-runtime && npm run build:theme:standalone && npm run package:artifact",
    "package:artifact": "node ../../scripts/package-app-platform-artifact.mjs",
    "build:admin-artifact": "npm run build:copied-routes-runtime && npm run package:admin-artifact",
    "package:admin-artifact": "node ../../scripts/package-app-platform-admin-artifact.mjs --app tailorkit",
    "build:product-editor-probe": "TAILORKIT_PRODUCT_EDITOR_BUILD_MODE=probe vite build --config vite.product-editor-island.config.mts",
    "build:product-editor-runtime": "TAILORKIT_PRODUCT_EDITOR_BUILD_MODE=runtime vite build --config vite.product-editor-island.config.mts",
    "build:copied-routes-runtime": "vite build --config vite.copied-routes.config.mts",
    "build:admin-runtime": "vite build --config vite.admin-runtime.config.mts"
  },
  "peerDependencies": {
    "@shopify/app-bridge-react": "^4.2.3",
    "@shopify/polaris": "13.9.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@huggingface/transformers": "^3.5.2",
    "@preact/signals": "^1.2.1",
    "@shopify/polaris-icons": "^9.3.1",
    "@svgdotjs/svg.js": "^3.2.5",
    "@xyflow/react": "^12.11.0",
    "dateformat": "^5.0.3",
    "dompurify": "^3.2.6",
    "i18next": "^23.11.4",
    "konva": "^10.0.12",
    "liquidjs": "^10.27.0",
    "marked": "^15.0.12",
    "mixpanel-browser": "^2.80.0",
    "numeral": "^2.0.6",
    "p-throttle": "^7.0.0",
    "pako": "^2.2.0",
    "preact": "^10.27.0",
    "psd-vanilla-js": "^0.1.40",
    "react-device-detect": "^2.2.3",
    "react-i18next": "^14.1.3",
    "react-konva": "^18.2.16",
    "react-quill-new": "^3.8.3",
    "react-zoom-pan-pinch": "^3.7.0",
    "socket.io-client": "^4.8.3",
    "tinycolor2": "^1.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/dateformat": "^5.0.3"
  }
}
