  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "resolutions": {
    "undici": "6.13.0",
    "vitest/vite": "npm:rolldown-vite@7.3.1"
  },
  "overrides": {
    "undici": "6.13.0"
  },
  "lint-staged": {
    "!(marketing|.claude|public|Analytics)/**/*.{js,jsx,ts,tsx,d.ts}": [
      "npm run format",
      "node scripts/generate-translations.cjs",
      "eslint --no-ignore --max-warnings=0 --ignore-pattern '.claude/**' --ignore-pattern 'marketing/**' --ignore-pattern 'public/**' --ignore-pattern 'Analytics/**'"
    ]
  }
