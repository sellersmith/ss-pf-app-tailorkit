{
  "name": "tailorkit",
  "author": "Ecomate",
  "private": true,
  "version": "1.36.6",
  "description": "TailorKit Product Personalizer",
  "scripts": {
    "dev": "mkdir -p logs && yarn build-ext && node scripts/toggle-app-proxy.js --enable && NODE_ENV=development ./scripts/script-log.sh logs/dev.log ./scripts/shopify-dev.sh",
    "dev:localhost": "mkdir -p logs && yarn build-ext && node scripts/toggle-app-proxy.js --disable && NODE_ENV=development SHOPIFY_APP_URL=https://localhost:3458 ./scripts/script-log.sh logs/dev.log ./scripts/shopify-dev.sh --use-localhost",
    "dev:react-devtools": "npx react-devtools & cross-env ENABLE_DEVTOOLS=true yarn dev",
    "dev-ext": "cd extensions && yarn install && yarn dev",
    "build-ext": "cd extensions && yarn install && IS_PRODUCTION=true yarn build",
    "build": "yarn clean:exports && yarn build-ext && yarn config:use shopify.app.toml && NODE_ENV=production remix vite:build ",
    "build-rc": "yarn clean:exports && yarn build-ext && yarn config:use shopify.app.rc.toml && NODE_ENV=production remix vite:build ",
    "build-wip": "yarn clean:exports && yarn build-ext && yarn build-storybook && yarn config:use shopify.app.wip.toml && NODE_ENV=production remix vite:build ",
    "build-master": "yarn clean:exports && yarn build-ext && yarn config:use shopify.app.master.toml && NODE_ENV=production APP_CDN_URL=https://cdn-tailorkit.ecomate.co/ remix vite:build ",
    "deploy": "yarn shopify app deploy -f -c shopify.app.toml",
    "deploy-rc": "node scripts/check-deploy-env.js rc && yarn shopify app deploy -f -c shopify.app.rc.toml",
    "deploy-wip": "node scripts/check-deploy-env.js wip && yarn shopify app deploy -f -c shopify.app.wip.toml",
    "deploy-master": "node scripts/check-deploy-env.js master && yarn shopify app deploy -f -c shopify.app.master.toml",
    "vite": "vite",
    "shopify": "shopify",
    "env": "shopify app env",
    "docker-start": "npm run start",
    "generate": "shopify app generate",
    "config:use": "shopify app config use",
    "config:link": "shopify app config link",
    "server-start": "dotenv -e .env node server.js",
    "start": "node scripts/toggle-app-proxy.js --enable && NODE_ENV=production node server.js",
    "graphql-codegen": "graphql-codegen",
    "test": "cross-env NODE_ENV=test npx vitest",
    "test-once": "cross-env NODE_ENV=test npx vitest --run",
    "test:ci": "cross-env CI=true vitest --run",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "npm run lint -- --fix",
    "prettier": "prettier --cache --cache-location ./node_modules/.cache/prettier .",
    "prettier:fix": "npm run prettier -- --write",
    "format": "npm run prettier:fix && npm run lint:fix",
    "prepare": "husky && echo 'npx lint-staged && npm run build' > .husky/pre-commit",
    "sync-ai-rules": "cp .airules .windsurfrules",
    "clean:exports": "node scripts/cleanup-old-exports.js",
    "seed-templates": "node scripts/seed-templates.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "test:e2e": "npx playwright test --project=chromium",
    "test:e2e:headed": "npx playwright test --project=chromium --headed",
    "test:e2e:capture-auth": "npx playwright test --project=shopify-auth-capture --headed --debug",
    "test:e2e:debug": "npx playwright test --project=chromium --headed --debug",
    "test:e2e:report": "npx playwright show-report e2e/results/html",
    "marketing": "cd marketing && git init -q 2>/dev/null && claude",
    "marketing:ide": "code marketing/ --command claude-vscode.sidebar.open",
    "elva-kb:search": "npx tsx scripts/elva-kb/search.ts",
    "elva-kb:upsert": "npx tsx scripts/elva-kb/upsert.ts",
    "elva-kb:extract-ui-canon": "npx tsx scripts/elva-kb/extract-ui-canon-from-master.ts",
    "elva-kb:rollback": "npx tsx scripts/elva-kb/rollback.ts",
    "elva-kb:audit": "npx tsx scripts/elva-kb/audit.ts",
    "elva-kb:contradiction-scan": "npx tsx scripts/elva-kb/contradiction-scan.ts",
    "elva-kb:flag-reviewable": "npx tsx scripts/elva-kb/flag-reviewable-rows.ts"
  },
  "engines": {
    "node": ">=22.17.0"
  },
  "type": "module",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
