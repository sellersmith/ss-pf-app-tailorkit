{% if layer and layers and print_area %}
{% assign multi_layout_option_set = layer.osl | where: 't', 'multi_layout_option' | first %}{% assign layouts = multi_layout_option_set.ol %}
{% if layouts.size > 0 %}{% assign layout_selected = multi_layout_option_set.layoutSelected | default: layouts[0].v %}{% else %}{% assign layout_selected = '' %}{% endif %}
{% assign layout_selected_label = '' %}{% for layout in layouts %}{% if layout.v == layout_selected %}{% assign layout_selected_label = layout.l %}{% break %}{% endif %}{% endfor %}
{% assign is_dropdown = false %}{% if multi_layout_option_set.displayStyle == 'multi_layout_dropdown_list' %}{% assign is_dropdown = true %}{% endif %}
{% if multi_layout_option_set %}<div class='emtlkit--option-set-wrapper' style='{{ style }}'><div class='emtlkit--option-set-container'>
<fieldset class='emtlkit--option-set' data-print-area-id='{{ print_area.i }}' data-option-type='{{ multi_layout_option_set.t }}' data-layer-id='{{ layer_id }}' data-type='emtlkit--option-set' data-id='{{ multi_layout_option_set.i }}' data-label='{{ multi_layout_option_set.l | escape_once }}' data-layer-index='{{ forloop.parentloop.index0 }}' id='{{ 'option-set-' | append: multi_layout_option_set.i }}' value='{{ layout_selected }}' data-name='{{ multi_layout_option_set.l | escape_once }}'>
<label class='emtlkit--option-set-label'>{{ multi_layout_option_set.l }}: {{ layout_selected_label }}</label>
{% if is_dropdown %}<tailorkit-multi-layout-dropdown data-current-print-area-id='{{ print_area.i }}' data-current-option-set-id='{{ multi_layout_option_set.i }}' data-option-set-data='{{ multi_layout_option_set | json | escape_once }}'></tailorkit-multi-layout-dropdown>{% else %}<div class='emtlkit--d-flex emtlkit--flex-center emtlkit--gap-8 emtlkit--flex-wrap'>{% for layout in layouts %}{% assign layout_id = layout.v %}{% assign layout_label = layout.l %}{% assign class_name = 'emtlkit--option-container emtlkit-multi_layout-option emtlkit--thumbnail' %}{% assign checked = '' %}{% if layout_id == layout_selected %}{% assign checked = 'checked="checked"' %}{% assign class_name = class_name | append: ' active' %}{% endif %}<div class='{{ class_name }}'>{% assign thumbnail = layout.t %}<input type='radio' name='layout-{{ multi_layout_option_set.i }}' data-id='{{ layout_id }}' data-name='{{ layout_label }}' value='{{ layout_id }}' {{ checked }}>{% if thumbnail contains '<svg' %}{{ thumbnail }}{% else %}<img src='{{ thumbnail }}?width=60' width='60' height='60' alt='{{ layout_label }}'>{% endif %}</div>{% endfor %}</div>{% endif %}
</fieldset></div></div>
<div class='emtlkit--layout-option'>{% assign in_multi_layout = true %}{% for layout in layouts %}{% assign layer_ids = layout.ls %}{% for layer_id in layer_ids %}{% for layer in layers %}{% if layer.i == layer_id %}{% subsnippet 'render-layer' %}{% endif %}{% endfor %}{% endfor %}{% endfor %}{% assign in_multi_layout = false %}</div>
{% endif %}
{% endif %}
