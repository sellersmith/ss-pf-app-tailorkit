{
  "name": "ss-pf-app-tailorkit",
  "version": "0.1.0",
  "private": true,
  "description": "TailorKit admin artifact producer for PageFly app-platform",
  "license": "UNLICENSED",
  "type": "module",
  "main": "apps/tailorkit/src/index.ts",
  "exports": {
    ".": "./apps/tailorkit/src/index.ts",
    "./manifest": "./apps/tailorkit/manifest.ts",
    "./admin": "./apps/tailorkit/src/admin/index.tsx",
    "./product-editor-route-contract": "./apps/tailorkit/src/admin/product-editor-island/route-contract.ts",
    "./domain/order-record": "./apps/tailorkit/domain/order-record.ts",
    "./domain/order-property-matchers": "./apps/tailorkit/domain/order-property-matchers.ts"
  },
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "ci:contract": "node scripts/verify-ci-contract.mjs",
    "build:admin-artifact": "npm --workspace @pagefly/app-tailorkit run build:admin-artifact",
    "package:admin-artifact": "npm --workspace @pagefly/app-tailorkit run package:admin-artifact",
    "deploy:admin-artifact": "node scripts/deploy-app-platform-admin-artifact.mjs",
    "deploy:admin-artifact:dry-run": "node scripts/deploy-app-platform-admin-artifact.mjs --dry-run"
  },
  "dependencies": {
    "@shopify/cli": "^4.2.0",
    "cross-env": "7.0.3",
    "date-fns": "3.6.0",
    "date-fns-tz": "^3.1.3",
    "fs-extra": "10.1.0",
    "googleapis": "^155.0.0",
    "graphql": "15.8.0",
    "lodash": "4.17.21"
  },
  "devDependencies": {
    "@types/jest": "29.5.3",
    "@types/lodash": "^4.14.197",
    "@types/node": "24.10.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-for-of-loops": "^1.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-testing-library": "^7.13.3",
    "husky": "7.0.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "29.6.2",
    "jest-resolve": "29.6.2",
    "jest-watch-typeahead": "2.2.2",
    "lint-staged": "^13.2.3",
    "prettier": "^3.6.2",
    "ts-jest": "29.1.1",
    "typescript": "5.9.3",
    "vite": "^7.2.2",
    "vite-plugin-pwa": "^1.1.0",
    "vite-plugin-svgr": "^4.5.0",
    "vite-plugin-transform": "^2.0.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "workspaces": [
    "apps/*"
  ],
  "overrides": {
    "zod": "^4.4.3",
    "typeorm": "0.3.28",
    "better-sqlite3": "^11.10.0"
  }
}
